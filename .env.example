# Copy this file to .env and fill in your actual values
# IMPORTANT: Never commit .env to version control!

# HuggingFace token for model access
HF_TOKEN=your_huggingface_token_here

# LLM Configuration (Using Ollama or HuggingFace)
# Option 1: Local Ollama
#   1. Download and install Ollama from https://ollama.ai/download
#   2. Run: ollama run mistral
#   3. API will be available at http://localhost:11434
# Option 2: HuggingFace (requires HF_TOKEN)
#   Recommended for better performance
LLM_SERVER_URL=http://localhost:11434
LLM_MODEL=mistral

# Embedding Model Configuration
EMBEDDING_MODEL=UAE-Large-V1

# ChromaDB Telemetry (Disable to fix capture() argument error)
CHROMA_TELEMETRY_DISABLED=True
